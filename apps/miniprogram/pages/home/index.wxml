<view class="home-page">
  <view class="red-hero">
    <view class="hero-bak" aria-hidden="true">
      <image class="brand-title-bak" src="/assets/icons/title-bak.png" mode="aspectFill"></image>
    </view>
    <!-- <view class="hero-gamepad" aria-hidden="true">
      <view class="pad-body">
        <view class="pad-cross pad-cross-h"></view>
        <view class="pad-cross pad-cross-v"></view>
        <view class="pad-dot pad-dot-one"></view>
        <view class="pad-dot pad-dot-two"></view>
      </view>
    </view> -->
    <view class="hero-header">
      <view>
        <view class="brand-row">
          <view class="brand-title">
            <image class="brand-title-img" src="/assets/icons/title.png" mode="aspectFit"></image>
          </view>
        </view>
        <text class="brand-subtitle">记录买入、卖出和白玩战绩</text>
      </view>
      <button class="hero-search" hover-class="hero-search-hover" hover-stay-time="120" bindtap="onOpenSearch">
        <image class="search-icon-img" src="/assets/icons/search-white.svg" mode="aspectFit"></image>
      </button>
    </view>
  </view>

  <view class="content-shell">
    <view class="ledger-card">
      <view class="ledger-topline">
        <view class="ledger-left">
          <view class="level-chip">
            <image class="chip-icon-img" src="/assets/icons/trophy-white.svg" mode="aspectFit"></image>
            <text>Lv.4 骨灰玩家</text>
          </view>
          <view class="rate-chip">
            <text>回血率 {{summary.paybackRate}}%</text>
            <view class="rate-line">
              <view class="rate-fill" style="width: {{summary.paybackRate}}%;"></view>
            </view>
          </view>
        </view>
        <view class="round-info" hover-class="round-info-hover" hover-stay-time="120" bindtap="onOpenSummaryInfo">
          <image class="info-icon-img" src="/assets/icons/info.svg" mode="aspectFit"></image>
        </view>
      </view>

      <view class="actual-block">
        <text class="actual-label">实际花费 <text class="muted">(元)</text></text>
        <view class="actual-value">
          <text class="yuan">¥</text>
          <text class="big-number">{{summary.actualCost}}</text>
        </view>
      </view>

      <view class="summary-row">
        <view class="summary-cell">
          <text class="summary-name">买游戏花了</text>
          <text class="summary-num">¥{{summary.totalPurchaseCost}}</text>
        </view>
        <view class="summary-cell">
          <text class="summary-name">卖游戏回血</text>
          <text class="summary-num green">¥{{summary.totalSellPayback}}</text>
        </view>
        <view class="summary-cell">
          <text class="summary-name">当前持有</text>
          <text class="summary-num">{{summary.holdingCount}} 款</text>
        </view>
      </view>

      <view class="free-hint" bindtap="onOpenPaybackHint">
        <text>距离完全白玩还差 <text class="red-text">¥{{summary.remainingToFree}}</text></text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="quick-grid">
      <action-entry
        wx:for="{{quickActions}}"
        wx:key="key"
        action-key="{{item.key}}"
        label="{{item.label}}"
        icon-src="{{item.iconSrc}}"
        icon-class="{{item.iconClass}}"
        primary="{{item.primary}}"
        bindentrytap="onQuickAction"
      />
    </view>

    <section-card title="最近入库">
      <view slot="extra" class="plain-link" hover-class="plain-link-hover" hover-stay-time="120" bindtap="onViewLibrary">全部游戏 ›</view>

      <scroll-view class="games-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="games-strip">
          <game-cover-card wx:for="{{recentGames}}" wx:key="id" game="{{item}}" bindcardtap="onOpenGame" />
        </view>
      </scroll-view>
    </section-card>

    <view class="play-card">
      <view class="play-header">
        <view class="play-title">
          <image class="play-title-icon" src="/assets/icons/trophy-yellow.svg" mode="aspectFit"></image>
          <text>白玩战绩</text>
        </view>
        <view class="play-actions">
          <text class="heirloom-count">传家宝 {{achievement.collectionCount}} 款</text>
          <view class="dark-more" hover-class="dark-more-hover" hover-stay-time="120" bindtap="onOpenPlayStats">详情 ›</view>
        </view>
      </view>

      <view class="play-grid">
        <stat-card
          wx:for="{{achievementStats}}"
          wx:key="label"
          label="{{item.label}}"
          value="{{item.value}}"
          unit="{{item.unit}}"
          icon-src="{{item.iconSrc}}"
          icon-class="{{item.iconClass}}"
          highlight="{{item.highlight}}"
        />
      </view>
    </view>

    <section-card title="待处理游戏" spacing="compact" tab-safe="{{true}}">
      <view class="pending-card">
        <view wx:for="{{tasks}}" wx:key="title" class="pending-row" data-type="{{item.type}}" bindtap="onOpenTask">
          <view class="pending-icon {{item.iconClass}}">
            <image class="task-icon-img" src="{{item.iconSrc}}" mode="aspectFit"></image>
          </view>
          <view class="pending-copy">
            <text class="pending-title">{{item.title}}</text>
            <text class="pending-desc">{{item.desc}}</text>
          </view>
          <view class="pending-action" hover-class="pending-action-hover" hover-stay-time="120">{{item.actionText}} ›</view>
        </view>
      </view>
    </section-card>
  </view>

</view>
