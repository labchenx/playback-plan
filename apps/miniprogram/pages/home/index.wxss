page {
  background: #f4f5f8;
}

.home-page {
  min-height: 100vh;
  padding-bottom: 0;
  background: #f4f5f8;
  color: #111827;
  overflow-x: hidden;
}

button {
  box-sizing: border-box;
  min-width: 0;
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: 0;
}

.red-hero {
  position: relative;
  min-height: 314rpx;
  padding: 88rpx 36rpx 124rpx;
  overflow: hidden;
  border-bottom-left-radius: 66rpx;
  border-bottom-right-radius: 66rpx;
  background: linear-gradient(135deg, #ff453a 0%, #e3271e 52%, #b91c11 100%);
  box-shadow: 0 20rpx 54rpx rgba(239, 46, 40, 0.22);
}

.hero-bak {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 0;
  width: 100%;
  height: 100%;
  opacity: 0.96;
  pointer-events: none;
}

.brand-title-bak {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover; /* 保持比例并裁剪填满 */
}

.hero-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-header > view:first-child {
  flex: 1;
  min-width: 0;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.brand-title {
  flex: 0 0 340rpx;
  width: 340rpx;
  height: 79rpx;
  line-height: 1;
}

.brand-title-img {
  display: block;
  width: 100%;
  height: 100%;
}

.brand-emblem {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 37rpx;
  height: 37rpx;
  margin-top: 2rpx;
  transform: rotate(12deg);
}

.brand-icon-img {
  width: 44rpx;
  height: 44rpx;
}

.brand-subtitle {
  display: block;
  margin-top: 22rpx;
  margin-bottom: 10rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 18rpx;
  font-weight: 800;
}

.hero-search {
  flex: 0 0 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  margin-top: 2rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 120ms ease, background-color 120ms ease;
}

.hero-search-hover {
  transform: translateY(2rpx) scale(0.96);
  background: rgba(255, 255, 255, 0.18);
}

.search-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.content-shell {
  position: relative;
  z-index: 2;
  margin-top: -104rpx;
  padding: 0 24rpx;
}

.ledger-card {
  padding: 34rpx 34rpx 30rpx;
  border: 1rpx solid rgba(243, 244, 246, 0.5);
  border-radius: 40rpx;
  background: #ffffff;
  box-shadow: 0 13rpx 50rpx rgba(0, 0, 0, 0.06);
}

.ledger-topline,
.level-chip,
.rate-chip,
.actual-value,
.summary-row,
.free-hint,
.section-title-row,
.play-header,
.play-title,
.play-actions,
.stat-label-row,
.stat-value-row,
.pending-row {
  display: flex;
  align-items: center;
}

.ledger-topline {
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.ledger-left {
  display: flex;
  gap: 12rpx;
}

.level-chip {
  flex: none;
  height: 40rpx;
  gap: 7rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(251, 191, 36, 0.35);
  background: linear-gradient(90deg, #fbbf24, #d97706);
  color: #ffffff;
  font-size: 17rpx;
  font-weight: 900;
  white-space: nowrap;
  box-shadow: 0 6rpx 14rpx rgba(245, 158, 11, 0.2);
}

.chip-icon-img {
  width: 20rpx;
  height: 20rpx;
}

.rate-chip {
  flex: none;
  height: 36rpx;
  gap: 8rpx;
  padding: 0 14rpx;
  border: 1rpx solid #f3f4f6;
  border-radius: 999rpx;
  background: rgba(249, 250, 251, 0.88);
  color: #1f2937;
  font-size: 16rpx;
  font-weight: 900;
  white-space: nowrap;
}

.rate-line {
  width: 70rpx;
  height: 8rpx;
  overflow: hidden;
  border-radius: 99rpx;
  background: rgba(229, 231, 235, 0.88);
  box-shadow: inset 0 2rpx 3rpx rgba(0, 0, 0, 0.03);
}

.rate-fill {
  height: 100%;
  border-radius: 99rpx;
  background: #ef3c35;
}

.round-info {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: #f9fafb;
  color: #c5cad3;
  transition: transform 120ms ease;
}

.round-info-hover {
  transform: scale(0.92);
}

.info-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.actual-block {
  margin-bottom: 30rpx;
}

.actual-label {
  display: block;
  color: #9ca3af;
  font-size: 18rpx;
  font-weight: 800;
}

.muted {
  color: #cfd3da;
  font-weight: 600;
}

.actual-value {
  margin-top: 8rpx;
  align-items: baseline;
  color: #0f172a;
}

.yuan {
  margin-right: 2rpx;
  font-size: 40rpx;
  font-weight: 900;
}

.big-number {
  font-size: 74rpx;
  font-weight: 900;
  line-height: 0.95;
}

.summary-row {
  justify-content: space-between;
  gap: 16rpx;
  padding-top: 27rpx;
  border-top: 1rpx solid rgba(243, 244, 246, 0.85);
}

.summary-cell {
  min-width: 0;
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.summary-name {
  color: #9ca3af;
  font-size: 17rpx;
  font-weight: 800;
}

.summary-num {
  color: #111827;
  font-size: 22rpx;
  font-weight: 900;
}

.green {
  color: #10b981;
}

.free-hint {
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f2f5;
  color: #9ca3af;
  font-size: 21rpx;
  font-weight: 800;
}

.red-text {
  color: #ef3c35;
  font-weight: 900;
}

.arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: #f9fafb;
  color: #c4c8d0;
  font-size: 30rpx;
  line-height: 1;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin-top: 40rpx;
}

.quick-card {
  min-height: 164rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  border: 1rpx solid rgba(243, 244, 246, 0.8);
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 0 #f3f4f6, 0 11rpx 22rpx rgba(21, 29, 44, 0.03);
  transition: transform 120ms ease, box-shadow 120ms ease;
}

.quick-card-hover {
  transform: translateY(8rpx);
  box-shadow: 0 0 0 #f3f4f6, 0 7rpx 18rpx rgba(21, 29, 44, 0.03);
}

.quick-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  border-radius: 22rpx;
  background: #f9fafb;
  color: #4b5563;
}

.quick-icon-img {
  width: 62rpx;
  height: 62rpx;
}

.quick-label {
  color: #111827;
  font-size: 19rpx;
  font-weight: 900;
}

.section {
  margin-top: 50rpx;
}

.section-title-row {
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
  padding: 0 4rpx;
}

.section-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
}

.plain-link {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(243, 244, 246, 0.8);
  color: #6b7280;
  font-size: 18rpx;
  font-weight: 800;
  transition: transform 120ms ease, background-color 120ms ease;
}

.plain-link-hover {
  transform: translateY(2rpx);
  background: #e5e7eb;
}

.games-scroll {
  width: 100%;
  white-space: nowrap;
}

.games-strip {
  display: flex;
  gap: 27rpx;
  padding: 0 10rpx 24rpx 10rpx;
}

.mini-game {
  flex: 0 0 234rpx;
  width: 234rpx;
  white-space: normal;
}

.game-cover {
  position: relative;
  width: 234rpx;
  height: 268rpx;
  overflow: hidden;
  border: 1rpx solid rgba(243, 244, 246, 0.5);
  border-radius: 27rpx;
  background: #f3f4f6;
  box-shadow: 0 7rpx 20rpx rgba(0, 0, 0, 0.05);
}

.game-image {
  width: 100%;
  height: 100%;
}

.platform {
  position: absolute;
  top: 13rpx;
  left: 13rpx;
  min-width: 38rpx;
  padding: 3rpx 10rpx;
  border-radius: 7rpx;
  color: #ffffff;
  font-size: 15rpx;
  font-weight: 900;
  text-align: center;
  box-shadow: 0 3rpx 7rpx rgba(0, 0, 0, 0.1);
}

.platform-red {
  background: #ef3c35;
}

.platform-blue {
  background: #2563eb;
}

.heirloom {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  width: 118rpx;
  height: 118rpx;
}

.heirloom-icon-img {
  display: block;
  width: 100%;
  height: 100%;
}

.mini-title {
  display: -webkit-box;
  min-height: 56rpx;
  margin-top: 17rpx;
  overflow: hidden;
  color: #111827;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.28;
  text-overflow: ellipsis;
  white-space: normal;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.mini-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 9rpx;
}

.mini-price {
  color: #ef3c35;
  font-size: 25rpx;
  font-weight: 900;
}

.mini-status {
  flex: none;
  padding: 4rpx 13rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 17rpx;
  font-weight: 800;
}

.mini-note {
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  color: #b3bac5;
  font-size: 17rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.play-card {
  position: relative;
  margin-top: 28rpx;
  padding: 34rpx;
  overflow: hidden;
  border: 1rpx solid #1f2937;
  border-radius: 40rpx;
  background: #111827;
  box-shadow: 0 22rpx 42rpx rgba(17, 24, 39, 0.18);
}

.play-card::after {
  content: "";
  position: absolute;
  right: -82rpx;
  top: -82rpx;
  width: 268rpx;
  height: 268rpx;
  border-radius: 999rpx;
  background: rgba(59, 130, 246, 0.1);
}

.play-header {
  position: relative;
  z-index: 1;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.play-title {
  flex: 1;
  min-width: 0;
  gap: 10rpx;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 900;
}

.play-title-icon {
  flex: 0 0 28rpx;
  width: 28rpx;
  height: 28rpx;
}

.play-actions {
  flex: none;
  gap: 8rpx;
}

.heirloom-count {
  height: 32rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(245, 158, 11, 0.14);
  color: #f2b130;
  font-size: 16rpx;
  font-weight: 900;
  line-height: 32rpx;
}

.dark-more {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 34rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-size: 16rpx;
  font-weight: 900;
  transition: transform 120ms ease, background-color 120ms ease;
}

.dark-more-hover {
  transform: translateY(2rpx);
  background: rgba(255, 255, 255, 0.18);
}

.play-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.play-stat {
  min-height: 116rpx;
  padding: 21rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 27rpx;
  background: rgba(255, 255, 255, 0.055);
}

.hot-stat {
  background: linear-gradient(135deg, #ff3f34, #df211c);
}

.stat-label-row {
  gap: 8rpx;
  color: #9ca3af;
  font-size: 19rpx;
  font-weight: 800;
}

.hot-stat .stat-label-row {
  color: rgba(255, 255, 255, 0.88);
}

.stat-icon {
  width: 24rpx;
  height: 24rpx;
}

.stat-value-row {
  margin-top: 13rpx;
  align-items: baseline;
}

.stat-value {
  color: #ffffff;
  font-size: 35rpx;
  font-weight: 900;
  line-height: 1;
}

.hot-stat .stat-value {
  font-size: 46rpx;
}

.stat-unit {
  margin-left: 5rpx;
  color: #6b7280;
  font-size: 17rpx;
  font-weight: 800;
}

.pending-section {
  margin-top: 40rpx;
  margin-bottom: 292rpx;
}

.pending-card {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #f3f4f6;
  border-radius: 40rpx;
  background: #ffffff;
  box-shadow: 0 3rpx 25rpx rgba(0, 0, 0, 0.03);
}

.pending-row {
  min-height: 100rpx;
  gap: 20rpx;
  padding: 0 2rpx;
  border-radius: 27rpx;
}

.pending-row + .pending-row {
  border-top: 1rpx solid #f0f2f5;
}

.pending-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.03);
}

.task-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.task-icon-green {
  background: #eafaf3;
  color: #10b981;
}

.task-icon-amber {
  background: #fff8df;
  color: #d99a11;
}

.task-icon-blue {
  background: #edf5ff;
  color: #3b82f6;
}

.pending-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 7rpx;
}

.pending-title {
  color: #111827;
  font-size: 22rpx;
  font-weight: 900;
}

.pending-desc {
  overflow: hidden;
  color: #8b95a5;
  font-size: 18rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pending-action {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 999rpx;
  background: #ffffff;
  color: #374151;
  font-size: 18rpx;
  font-weight: 900;
  box-shadow: 0 4rpx 0 #f3f4f6;
  transition: transform 120ms ease, box-shadow 120ms ease, background-color 120ms ease;
}

.pending-action-hover {
  transform: translateY(4rpx);
  background: #f9fafb;
  box-shadow: 0 0 0 #f3f4f6;
}
