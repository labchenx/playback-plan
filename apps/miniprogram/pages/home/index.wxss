@import "../../styles/tokens.wxss";

page {
  background: var(--color-bg);
}

.home-page {
  min-height: 100vh;
  padding-bottom: 0;
  background: var(--color-bg);
  color: var(--color-text);
  overflow-x: hidden;
}

button {
  box-sizing: border-box;
  min-width: 0;
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: 0;
}

.red-hero {
  position: relative;
  min-height: 314rpx;
  padding: 88rpx 36rpx 124rpx;
  overflow: hidden;
  border-bottom-left-radius: var(--radius-hero);
  border-bottom-right-radius: var(--radius-hero);
  background: linear-gradient(135deg, var(--color-brand-bright) 0%, #e3271e 52%, var(--color-brand-deep) 100%);
  box-shadow: var(--shadow-brand);
}

.hero-bak {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 0;
  width: 100%;
  height: 100%;
  opacity: 0.96;
  pointer-events: none;
}

.brand-title-bak {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover; /* 保持比例并裁剪填满 */
}

.hero-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-6);
}

.hero-header > view:first-child {
  flex: 1;
  min-width: 0;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.brand-title {
  flex: 0 0 340rpx;
  width: 340rpx;
  height: 79rpx;
  line-height: 1;
}

.brand-title-img {
  display: block;
  width: 100%;
  height: 100%;
}

.brand-emblem {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 37rpx;
  height: 37rpx;
  margin-top: 2rpx;
  transform: rotate(12deg);
}

.brand-icon-img {
  width: 44rpx;
  height: 44rpx;
}

.brand-subtitle {
  display: block;
  margin-top: 22rpx;
  margin-bottom: 10rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: var(--font-small);
  font-weight: var(--weight-bold);
}

.hero-search {
  flex: 0 0 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  margin-top: 2rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform var(--motion-fast), background-color var(--motion-fast);
}

.hero-search-hover {
  transform: translateY(2rpx) scale(0.96);
  background: rgba(255, 255, 255, 0.18);
}

.search-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.content-shell {
  position: relative;
  z-index: 2;
  margin-top: -104rpx;
  padding: 0 24rpx;
}

.ledger-card {
  padding: var(--space-8) var(--space-8) 30rpx;
  border: 1rpx solid rgba(243, 244, 246, 0.5);
  border-radius: var(--radius-xl);
  background: var(--color-surface);
  box-shadow: var(--shadow-soft);
}

.ledger-topline,
.level-chip,
.rate-chip,
.actual-value,
.summary-row,
.free-hint,
.play-header,
.play-title,
.play-actions,
.pending-row {
  display: flex;
  align-items: center;
}

.ledger-topline {
  justify-content: space-between;
  gap: var(--space-3);
  margin-bottom: 32rpx;
}

.ledger-left {
  display: flex;
  gap: var(--space-3);
}

.level-chip {
  flex: none;
  height: 40rpx;
  gap: 7rpx;
  padding: 0 18rpx;
  border-radius: var(--radius-pill);
  border: 1rpx solid rgba(251, 191, 36, 0.35);
  background: linear-gradient(90deg, #fbbf24, #d97706);
  color: #ffffff;
  font-size: var(--font-meta);
  font-weight: var(--weight-black);
  white-space: nowrap;
  box-shadow: 0 6rpx 14rpx rgba(245, 158, 11, 0.2);
}

.chip-icon-img {
  width: 20rpx;
  height: 20rpx;
}

.rate-chip {
  flex: none;
  height: 36rpx;
  gap: var(--space-2);
  padding: 0 14rpx;
  border: 1rpx solid var(--color-line);
  border-radius: var(--radius-pill);
  background: rgba(249, 250, 251, 0.88);
  color: #1f2937;
  font-size: var(--font-caption);
  font-weight: var(--weight-black);
  white-space: nowrap;
}

.rate-line {
  width: 70rpx;
  height: 8rpx;
  overflow: hidden;
  border-radius: 99rpx;
  background: rgba(229, 231, 235, 0.88);
  box-shadow: inset 0 2rpx 3rpx rgba(0, 0, 0, 0.03);
}

.rate-fill {
  height: 100%;
  border-radius: var(--radius-pill);
  background: var(--color-brand);
}

.round-info {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: var(--radius-pill);
  background: var(--color-surface-muted);
  color: #c5cad3;
  transition: transform var(--motion-fast);
}

.round-info-hover {
  transform: scale(0.92);
}

.info-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.actual-block {
  margin-bottom: 30rpx;
}

.actual-label {
  display: block;
  color: var(--color-text-muted);
  font-size: var(--font-small);
  font-weight: var(--weight-bold);
}

.muted {
  color: var(--color-text-faint);
  font-weight: var(--weight-medium);
}

.actual-value {
  margin-top: 8rpx;
  align-items: baseline;
  color: var(--color-text-strong);
}

.yuan {
  margin-right: 2rpx;
  font-size: 40rpx;
  font-weight: var(--weight-black);
}

.big-number {
  font-size: var(--font-hero-number);
  font-weight: var(--weight-black);
  line-height: 0.95;
}

.summary-row {
  justify-content: space-between;
  gap: var(--space-4);
  padding-top: 27rpx;
  border-top: 1rpx solid rgba(243, 244, 246, 0.85);
}

.summary-cell {
  min-width: 0;
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: var(--space-2);
}

.summary-name {
  color: var(--color-text-muted);
  font-size: var(--font-meta);
  font-weight: var(--weight-bold);
}

.summary-num {
  color: var(--color-text);
  font-size: 22rpx;
  font-weight: var(--weight-black);
}

.green {
  color: var(--color-success);
}

.free-hint {
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f2f5;
  color: var(--color-text-muted);
  font-size: var(--font-body);
  font-weight: var(--weight-bold);
}

.red-text {
  color: var(--color-brand);
  font-weight: var(--weight-black);
}

.arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: var(--radius-pill);
  background: var(--color-surface-muted);
  color: #c4c8d0;
  font-size: 30rpx;
  line-height: 1;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-5);
  margin-top: 40rpx;
}

.plain-link {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-pill);
  background: rgba(243, 244, 246, 0.8);
  color: var(--color-text-secondary);
  font-size: var(--font-small);
  font-weight: var(--weight-bold);
  transition: transform var(--motion-fast), background-color var(--motion-fast);
}

.plain-link-hover {
  transform: translateY(2rpx);
  background: var(--color-line-strong);
}

.games-scroll {
  width: 100%;
  white-space: nowrap;
}

.games-strip {
  display: flex;
  gap: 27rpx;
  padding: 0 10rpx 24rpx 10rpx;
}

.play-card {
  position: relative;
  margin-top: 28rpx;
  padding: 34rpx;
  overflow: hidden;
  border: 1rpx solid #1f2937;
  border-radius: var(--radius-xl);
  background: var(--color-dark);
  box-shadow: var(--shadow-dark);
}

.play-card::after {
  content: "";
  position: absolute;
  right: -82rpx;
  top: -82rpx;
  width: 268rpx;
  height: 268rpx;
  border-radius: 999rpx;
  background: rgba(59, 130, 246, 0.1);
}

.play-header {
  position: relative;
  z-index: 1;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-4);
  margin-bottom: 22rpx;
}

.play-title {
  flex: 1;
  min-width: 0;
  gap: 10rpx;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: var(--weight-black);
}

.play-title-icon {
  flex: 0 0 28rpx;
  width: 28rpx;
  height: 28rpx;
}

.play-actions {
  flex: none;
  gap: var(--space-2);
}

.heirloom-count {
  height: 32rpx;
  padding: 0 12rpx;
  border-radius: var(--radius-pill);
  background: rgba(245, 158, 11, 0.14);
  color: #f2b130;
  font-size: var(--font-caption);
  font-weight: var(--weight-black);
  line-height: 32rpx;
}

.dark-more {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 34rpx;
  padding: 0 14rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-size: var(--font-caption);
  font-weight: var(--weight-black);
  transition: transform var(--motion-fast), background-color var(--motion-fast);
}

.dark-more-hover {
  transform: translateY(2rpx);
  background: rgba(255, 255, 255, 0.18);
}

.play-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-5);
}

.pending-card {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid var(--color-line);
  border-radius: var(--radius-xl);
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.pending-row {
  min-height: 100rpx;
  gap: var(--space-5);
  padding: 0 2rpx;
  border-radius: var(--radius-md);
}

.pending-row + .pending-row {
  border-top: 1rpx solid #f0f2f5;
}

.pending-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  border-radius: var(--radius-pill);
  font-size: 20rpx;
  font-weight: var(--weight-black);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.03);
}

.task-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.task-icon-green {
  background: #eafaf3;
  color: var(--color-success);
}

.task-icon-amber {
  background: #fff8df;
  color: #d99a11;
}

.task-icon-blue {
  background: #edf5ff;
  color: var(--color-info);
}

.pending-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--radius-xs);
}

.pending-title {
  color: var(--color-text);
  font-size: 22rpx;
  font-weight: var(--weight-black);
}

.pending-desc {
  overflow: hidden;
  color: #8b95a5;
  font-size: 18rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pending-action {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border: 1rpx solid var(--color-line-strong);
  border-radius: var(--radius-pill);
  background: var(--color-surface);
  color: #374151;
  font-size: 18rpx;
  font-weight: var(--weight-black);
  box-shadow: 0 4rpx 0 #f3f4f6;
  transition: transform var(--motion-fast), box-shadow var(--motion-fast), background-color var(--motion-fast);
}

.pending-action-hover {
  transform: translateY(4rpx);
  background: var(--color-surface-muted);
  box-shadow: 0 0 0 #f3f4f6;
}
