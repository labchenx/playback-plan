@import "../../styles/common.wxss";

page {
  background: var(--color-bg);
}

.result-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: var(--color-bg);
  color: var(--color-text);
}

.result-hero {
  position: relative;
  min-height: 396rpx;
  padding: 82rpx 40rpx 120rpx;
  overflow: hidden;
  border-bottom-left-radius: var(--radius-hero);
  border-bottom-right-radius: var(--radius-hero);
  background: linear-gradient(145deg, var(--color-brand-bright) 0%, #e3271e 54%, var(--color-brand-deep) 100%);
  box-shadow: var(--shadow-brand);
}

.hero-glow {
  position: absolute;
  border-radius: var(--radius-pill);
  pointer-events: none;
}

.hero-glow-gold {
  top: -32rpx;
  right: -92rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(253, 199, 0, 0.18);
  filter: blur(58rpx);
}

.hero-glow-white {
  left: 72rpx;
  top: 142rpx;
  width: 210rpx;
  height: 210rpx;
  background: rgba(255, 255, 255, 0.1);
  filter: blur(44rpx);
}

.hero-gamepad {
  position: absolute;
  left: 50%;
  top: 118rpx;
  width: 330rpx;
  height: 212rpx;
  margin-left: -165rpx;
  border: 20rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 88rpx;
}

.pad-line,
.pad-dot {
  position: absolute;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.08);
}

.pad-line-one {
  left: 70rpx;
  top: 92rpx;
  width: 72rpx;
  height: 18rpx;
}

.pad-line-two {
  left: 97rpx;
  top: 65rpx;
  width: 18rpx;
  height: 72rpx;
}

.pad-dot {
  width: 22rpx;
  height: 22rpx;
}

.pad-dot-one {
  right: 76rpx;
  top: 70rpx;
}

.pad-dot-two {
  right: 42rpx;
  top: 116rpx;
}

.hero-nav,
.circle-button,
.hero-result,
.index-pill,
.game-card,
.tag-row,
.data-grid,
.metric-card,
.final-strip,
.final-left,
.final-icon,
.bottom-actions,
.primary-button,
.secondary-row,
.secondary-button,
.state-card,
.state-button {
  display: flex;
  align-items: center;
}

.hero-nav {
  position: relative;
  z-index: 2;
  justify-content: space-between;
}

.circle-button {
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  transition: transform var(--motion-fast), background-color var(--motion-fast);
}

.circle-button-hover {
  transform: scale(0.94);
  background: rgba(255, 255, 255, 0.2);
}

.back-chevron {
  width: 17rpx;
  height: 17rpx;
  margin-left: 6rpx;
  border-left: 6rpx solid #ffffff;
  border-bottom: 6rpx solid #ffffff;
  border-radius: 3rpx;
  transform: rotate(45deg);
}

.close-mark {
  margin-top: -3rpx;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: var(--weight-bold);
  line-height: 1;
}

.hero-result {
  position: relative;
  z-index: 1;
  flex-direction: column;
  justify-content: center;
  margin-top: 10rpx;
  text-align: center;
}

.saved-pill {
  height: 42rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.86);
  font-size: var(--font-caption);
  font-weight: var(--weight-black);
  letter-spacing: 1rpx;
  line-height: 42rpx;
}

.level-wrap {
  position: relative;
  margin-top: 22rpx;
}

.level-title {
  display: block;
  color: #ffffff;
  font-size: 52rpx;
  font-weight: var(--weight-black);
  line-height: 1.15;
  text-shadow: 0 6rpx 8rpx rgba(0, 0, 0, 0.14);
}

.spark {
  position: absolute;
  color: #fde68a;
  font-size: 34rpx;
  font-weight: var(--weight-black);
}

.spark-left {
  left: -40rpx;
  top: 24rpx;
}

.spark-right {
  right: -40rpx;
  top: -14rpx;
}

.index-pill {
  justify-content: center;
  gap: 12rpx;
  min-width: 318rpx;
  min-height: 84rpx;
  margin-top: 30rpx;
  padding: 0 34rpx;
  border: 4rpx solid #fde68a;
  border-radius: var(--radius-pill);
  background: linear-gradient(180deg, #fffbeb 0%, #fef3c7 100%);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.index-icon {
  width: 36rpx;
  height: 36rpx;
}

.index-label {
  color: #92400e;
  font-size: var(--font-small);
  font-weight: var(--weight-black);
}

.index-number {
  margin-left: 4rpx;
  color: var(--color-brand-bright);
  font-size: 62rpx;
  font-weight: var(--weight-black);
  line-height: 1;
}

.hero-result-state {
  min-height: 190rpx;
}

.state-hero-title {
  margin-top: 22rpx;
  font-size: 44rpx;
}

.result-shell {
  position: relative;
  z-index: 2;
  margin-top: -78rpx;
  padding: 0 24rpx calc(234rpx + env(safe-area-inset-bottom));
}

.game-card,
.metric-card,
.summary-card,
.state-card {
  border: 1rpx solid rgba(243, 244, 246, 0.86);
  background: rgba(255, 255, 255, 0.98);
  box-shadow: var(--shadow-soft);
}

.game-card {
  gap: 24rpx;
  min-height: 156rpx;
  padding: 24rpx;
  border-radius: var(--radius-xl);
}

.cover-box {
  flex: 0 0 112rpx;
  width: 112rpx;
  height: 150rpx;
  overflow: hidden;
  border: 1rpx solid var(--color-line);
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(239, 60, 53, 0.12), rgba(37, 99, 235, 0.1));
  box-shadow: var(--shadow-cover);
}

.cover-image {
  display: block;
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  width: 100%;
  height: 100%;
  color: rgba(239, 60, 53, 0.34);
}

.cover-main {
  font-size: 52rpx;
  font-weight: var(--weight-black);
  line-height: 1;
}

.cover-sub {
  margin-top: 8rpx;
  color: rgba(17, 24, 39, 0.36);
  font-size: var(--font-meta);
  font-weight: var(--weight-black);
}

.game-main {
  flex: 1;
  min-width: 0;
}

.game-name {
  display: -webkit-box;
  overflow: hidden;
  color: #101828;
  font-size: 28rpx;
  font-weight: var(--weight-black);
  line-height: 1.28;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.tag-row {
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.media-pill {
  height: 38rpx;
  padding: 0 14rpx;
  border-radius: var(--radius-xs);
  background: var(--color-line);
  color: #4a5565;
  font-size: var(--font-meta);
  font-weight: var(--weight-black);
  line-height: 38rpx;
}

.holding-text {
  display: block;
  margin-top: 16rpx;
  color: #99a1af;
  font-size: var(--font-small);
  font-weight: var(--weight-bold);
}

.data-grid {
  align-items: stretch;
  gap: 20rpx;
  margin-top: 24rpx;
}

.metric-card {
  justify-content: space-between;
  flex: 1;
  flex-direction: column;
  min-width: 0;
  min-height: 104rpx;
  padding: 24rpx;
  border-radius: var(--radius-lg);
}

.metric-label {
  color: #99a1af;
  font-size: var(--font-small);
  font-weight: var(--weight-bold);
}

.metric-value {
  margin-top: 14rpx;
  color: #101828;
  font-size: 36rpx;
  font-weight: var(--weight-black);
  line-height: 1;
}

.metric-success {
  color: var(--color-success);
}

.final-strip {
  justify-content: space-between;
  gap: 24rpx;
  min-height: 88rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(255, 59, 48, 0.2);
  border-radius: var(--radius-lg);
  background: rgba(255, 59, 48, 0.05);
}

.final-strip-free {
  border-color: rgba(16, 185, 129, 0.22);
  background: rgba(16, 185, 129, 0.08);
}

.final-strip-cost {
  border-color: rgba(245, 158, 11, 0.22);
  background: rgba(255, 251, 235, 0.84);
}

.final-left {
  gap: 14rpx;
  min-width: 0;
}

.final-icon {
  justify-content: center;
  flex: 0 0 44rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 59, 48, 0.1);
}

.final-strip-free .final-icon {
  background: rgba(16, 185, 129, 0.12);
}

.final-strip-cost .final-icon {
  background: rgba(245, 158, 11, 0.12);
}

.final-icon image {
  width: 24rpx;
  height: 24rpx;
}

.final-label {
  color: #101828;
  font-size: 25rpx;
  font-weight: var(--weight-black);
}

.final-value {
  flex: none;
  color: var(--color-brand-bright);
  font-size: 44rpx;
  font-weight: var(--weight-black);
  line-height: 1;
}

.final-strip-free .final-value {
  color: var(--color-success);
}

.final-strip-cost .final-value {
  color: #d97706;
  font-size: 38rpx;
}

.summary-card {
  margin-top: 24rpx;
  padding: 36rpx 32rpx;
  border-radius: var(--radius-xl);
  text-align: center;
}

.summary-copy {
  color: #1e2939;
  font-size: 28rpx;
  font-weight: var(--weight-black);
  line-height: 1.65;
}

.summary-highlight {
  color: var(--color-brand-bright);
  font-size: 34rpx;
  font-weight: var(--weight-black);
}

.bottom-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 30;
  flex-direction: column;
  align-items: stretch;
  gap: var(--space-4);
  padding: 24rpx 32rpx calc(34rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--color-line);
  border-top-left-radius: 44rpx;
  border-top-right-radius: 44rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -20rpx 60rpx rgba(0, 0, 0, 0.06);
}

.primary-button,
.secondary-button {
  justify-content: center;
  min-height: 88rpx;
  border-radius: var(--radius-lg);
  font-weight: var(--weight-black);
  transition: transform var(--motion-fast), box-shadow var(--motion-fast), background-color var(--motion-fast);
}

.primary-button {
  background: var(--color-brand-bright);
  color: #ffffff;
  font-size: 28rpx;
  box-shadow: 0 8rpx 0 #cc2118, 0 16rpx 28rpx rgba(239, 60, 53, 0.22);
}

.primary-button-hover {
  transform: translateY(6rpx);
  box-shadow: 0 2rpx 0 #cc2118, 0 8rpx 18rpx rgba(239, 60, 53, 0.18);
}

.secondary-row {
  align-items: stretch;
  gap: var(--space-4);
}

.secondary-button {
  flex: 1;
  min-width: 0;
  gap: 6rpx;
  border: 1rpx solid var(--color-line-strong);
  background: var(--color-surface-muted);
  color: #4a5565;
  font-size: 24rpx;
}

.secondary-button-hover {
  transform: translateY(3rpx);
  background: var(--color-line);
}

.button-arrow {
  color: #6a7282;
  font-size: 30rpx;
  font-weight: var(--weight-black);
}

.state-card {
  justify-content: center;
  flex-direction: column;
  min-height: 420rpx;
  padding: 70rpx 36rpx;
  border-radius: var(--radius-xl);
  text-align: center;
}

.loading-mark,
.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: var(--radius-pill);
  background: rgba(239, 60, 53, 0.08);
  color: var(--color-brand);
  font-size: 44rpx;
  font-weight: var(--weight-black);
}

.loading-mark {
  border: 8rpx solid rgba(239, 60, 53, 0.12);
  border-top-color: var(--color-brand);
}

.state-title {
  margin-top: 26rpx;
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: var(--weight-black);
}

.state-desc {
  margin-top: 12rpx;
  color: var(--color-text-muted);
  font-size: var(--font-body);
  font-weight: var(--weight-bold);
  line-height: 1.5;
}

.state-button {
  justify-content: center;
  min-height: 88rpx;
  margin-top: 34rpx;
  padding: 0 34rpx;
  border-radius: var(--radius-lg);
  background: var(--color-brand-bright);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: var(--weight-black);
  box-shadow: 0 8rpx 0 #cc2118, 0 16rpx 28rpx rgba(239, 60, 53, 0.22);
  transition: transform var(--motion-fast), box-shadow var(--motion-fast);
}

.state-button-hover {
  transform: translateY(6rpx);
  box-shadow: 0 2rpx 0 #cc2118, 0 8rpx 18rpx rgba(239, 60, 53, 0.18);
}
