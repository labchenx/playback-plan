<view class="result-page">
  <view class="result-hero">
    <view class="hero-glow hero-glow-gold"></view>
    <view class="hero-glow hero-glow-white"></view>
    <view class="hero-gamepad" aria-hidden="true">
      <view class="pad-line pad-line-one"></view>
      <view class="pad-line pad-line-two"></view>
      <view class="pad-dot pad-dot-one"></view>
      <view class="pad-dot pad-dot-two"></view>
    </view>

    <view class="hero-nav">
      <view class="circle-button" hover-class="circle-button-hover" hover-stay-time="120" bindtap="onBack">
        <view class="back-chevron"></view>
      </view>
      <view class="circle-button" hover-class="circle-button-hover" hover-stay-time="120" bindtap="onClose">
        <text class="close-mark">×</text>
      </view>
    </view>

    <view wx:if="{{!isLoading && !notFound && !blockedMessage && result}}" class="hero-result">
      <view class="saved-pill">卖出记录已保存</view>
      <view class="level-wrap">
        <text class="spark spark-left">✦</text>
        <text class="level-title">{{result.playLevelText}}</text>
        <text class="spark spark-right">✦</text>
      </view>
      <view class="index-pill">
        <image class="index-icon" src="/assets/icons/stat-fire.svg" mode="aspectFit"></image>
        <text class="index-label">白玩指数</text>
        <text class="index-number">{{result.playIndexText}}</text>
      </view>
    </view>

    <view wx:else class="hero-result hero-result-state">
      <view class="saved-pill">卖出结果</view>
      <text class="level-title state-hero-title">{{isLoading ? '正在生成' : '暂时不能展示'}}</text>
    </view>
  </view>

  <view class="result-shell">
    <view wx:if="{{isLoading}}" class="state-card">
      <view class="loading-mark"></view>
      <text class="state-title">正在生成卖出结果</text>
      <text class="state-desc">请稍等一下</text>
    </view>

    <view wx:elif="{{notFound}}" class="state-card">
      <view class="empty-icon">!</view>
      <text class="state-title">没有找到这款游戏</text>
      <text class="state-desc">可以回到游戏库确认记录是否还在</text>
      <view class="state-button" hover-class="state-button-hover" hover-stay-time="120" bindtap="onReturnLibrary">返回游戏库</view>
    </view>

    <view wx:elif="{{blockedMessage}}" class="state-card">
      <view class="empty-icon">!</view>
      <text class="state-title">{{blockedMessage}}</text>
      <text class="state-desc">卖出结果页只适用于实体版已出售游戏，正在返回游戏详情页</text>
    </view>

    <block wx:else>
      <view class="game-card">
        <view class="cover-box">
          <image wx:if="{{result.hasCover}}" class="cover-image" src="{{result.coverUrl}}" mode="aspectFill"></image>
          <view wx:else class="cover-placeholder">
            <text class="cover-main">游</text>
            <text class="cover-sub">{{result.platformText}}</text>
          </view>
        </view>

        <view class="game-main">
          <text class="game-name">{{result.name}}</text>
          <view class="tag-row">
            <view class="media-pill">{{result.mediaTypeText}}</view>
            <status-tag text="{{result.platformText}}" variant="{{result.platformClass}}" />
            <status-tag text="{{result.statusText}}" variant="muted" />
          </view>
          <text class="holding-text">{{result.holdingDaysText}}</text>
        </view>
      </view>

      <view class="data-grid">
        <view class="metric-card">
          <text class="metric-label">买入花费</text>
          <text class="metric-value">{{result.purchaseTotalText}}</text>
        </view>
        <view class="metric-card">
          <text class="metric-label">卖出回血</text>
          <text class="metric-value metric-success">{{result.sellNetAmountText}}</text>
        </view>
      </view>

      <view class="final-strip final-strip-{{result.resultTone}}">
        <view class="final-left">
          <view class="final-icon">
            <image src="/assets/icons/trophy-yellow.svg" mode="aspectFit"></image>
          </view>
          <text class="final-label">{{result.finalCostLabel}}</text>
        </view>
        <text class="final-value">{{result.finalCostValueText}}</text>
      </view>

      <view class="summary-card">
        <text class="summary-copy">
          {{result.summaryLineBefore}}<text class="summary-highlight">{{result.summaryAmountText}}</text>{{result.summaryLineAfter}}
        </text>
      </view>
    </block>
  </view>

  <view wx:if="{{!isLoading && !notFound && !blockedMessage && result}}" class="bottom-actions">
    <view class="primary-button" hover-class="primary-button-hover" hover-stay-time="120" bindtap="onComplete">完成</view>
    <view class="secondary-row">
      <view class="secondary-button" hover-class="secondary-button-hover" hover-stay-time="120" bindtap="onViewDetail">
        <text>查看游戏详情</text>
        <text class="button-arrow">›</text>
      </view>
      <view class="secondary-button" hover-class="secondary-button-hover" hover-stay-time="120" bindtap="onContinueSell">
        <text>继续记录卖出</text>
        <text class="button-arrow">›</text>
      </view>
    </view>
  </view>
</view>
