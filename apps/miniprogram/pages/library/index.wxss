@import "../../styles/common.wxss";

page {
  background: var(--color-bg);
}

.library-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: var(--color-bg);
  color: var(--color-text);
}

input,
scroll-view {
  box-sizing: border-box;
  min-width: 0;
}

.library-hero {
  position: relative;
  min-height: 214rpx;
  padding: 88rpx 40rpx 70rpx;
  overflow: hidden;
  border-bottom-left-radius: var(--radius-hero);
  border-bottom-right-radius: var(--radius-hero);
  background: linear-gradient(135deg, var(--color-brand-bright) 0%, #e3271e 54%, var(--color-brand-deep) 100%);
  box-shadow: var(--shadow-brand);
}

.hero-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-6);
}

.title-block {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.page-title {
  color: #ffffff;
  font-size: 46rpx;
  font-weight: var(--weight-black);
  line-height: 1.12;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
}

.page-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: var(--font-small);
  font-weight: var(--weight-bold);
}

.hero-tool {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 7rpx;
  width: 64rpx;
  height: 64rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.1);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.hero-tool-line {
  display: block;
  width: 28rpx;
  height: 4rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.92);
}

.hero-tool-line-short {
  width: 18rpx;
}

.library-shell {
  position: relative;
  z-index: 2;
  margin-top: -38rpx;
  padding: 0 28rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 18rpx;
  height: 78rpx;
  padding: 0 30rpx;
  border: 1rpx solid rgba(243, 244, 246, 0.86);
  border-radius: var(--radius-pill);
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  flex: none;
  color: #9aa3af;
  font-size: 30rpx;
  font-weight: var(--weight-medium);
  line-height: 1;
}

.search-input {
  flex: 1;
  height: 100%;
  color: var(--color-text);
  font-size: 24rpx;
  font-weight: var(--weight-medium);
}

.input-placeholder {
  color: #99a1af;
  font-weight: var(--weight-medium);
}

.filter-panel {
  margin: 32rpx -28rpx 0;
  padding: 0 28rpx 22rpx;
  border-bottom: 1rpx solid rgba(243, 244, 246, 0.72);
  background: rgba(249, 250, 251, 0.9);
}

.media-segment {
  display: flex;
  height: 68rpx;
  padding: 8rpx;
  border: 1rpx solid rgba(229, 231, 235, 0.58);
  border-radius: var(--radius-pill);
  background: rgba(243, 244, 246, 0.86);
}

.media-segment-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-pill);
  color: #6a7282;
  font-size: 22rpx;
  font-weight: var(--weight-black);
  transition: transform var(--motion-fast), background-color var(--motion-fast), box-shadow var(--motion-fast);
}

.media-segment-active {
  background: #ffffff;
  color: var(--color-text);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.04);
}

.status-scroll {
  width: 100%;
  margin: 22rpx -28rpx 0;
  white-space: nowrap;
}

.status-strip {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 28rpx 6rpx;
}

.status-chip {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 84rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border: 1rpx solid var(--color-line-strong);
  border-radius: var(--radius-pill);
  background: #ffffff;
  color: #4a5565;
  font-size: 21rpx;
  font-weight: var(--weight-bold);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  white-space: nowrap;
  transition: transform var(--motion-fast), box-shadow var(--motion-fast), background-color var(--motion-fast);
}

.status-chip-active {
  border-color: #1e2939;
  background: #1e2939;
  color: #ffffff;
  box-shadow: none;
}

.chip-hover {
  transform: translateY(3rpx);
}

.library-shell .section-card-compact {
  margin-top: 28rpx;
}

.game-list {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.game-card {
  display: flex;
  gap: 24rpx;
  min-height: 218rpx;
  padding: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(243, 244, 246, 0.86);
  border-radius: 40rpx;
  background: var(--color-surface);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
  transition: transform var(--motion-fast), box-shadow var(--motion-fast);
}

.game-card-hover {
  transform: translateY(4rpx);
  box-shadow: 0 3rpx 16rpx rgba(0, 0, 0, 0.04);
}

.cover-box {
  position: relative;
  flex: 0 0 168rpx;
  width: 168rpx;
  height: 216rpx;
  overflow: hidden;
  border: 1rpx solid rgba(243, 244, 246, 0.72);
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(239, 60, 53, 0.1), rgba(59, 130, 246, 0.08));
  box-shadow: var(--shadow-cover);
}

.cover-image {
  display: block;
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  width: 100%;
  height: 100%;
  color: rgba(239, 60, 53, 0.34);
}

.cover-placeholder-main {
  font-size: 58rpx;
  font-weight: var(--weight-black);
  line-height: 1;
}

.cover-placeholder-sub {
  margin-top: 10rpx;
  color: rgba(17, 24, 39, 0.36);
  font-size: var(--font-meta);
  font-weight: var(--weight-black);
}

.cover-heirloom {
  position: absolute;
  right: 9rpx;
  bottom: 9rpx;
  height: 26rpx;
  padding: 0 11rpx;
  border-radius: var(--radius-pill);
  background: #fff8df;
  color: #d99a11;
  font-size: 15rpx;
  font-weight: var(--weight-black);
  line-height: 26rpx;
}

.game-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  padding: 4rpx 0 0;
}

.game-title {
  display: -webkit-box;
  overflow: hidden;
  color: #101828;
  font-size: 26rpx;
  font-weight: var(--weight-black);
  line-height: 1.28;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.tag-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  min-height: 38rpx;
  margin-top: 12rpx;
}

.media-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  height: 36rpx;
  padding: 0 12rpx;
  border: 1rpx solid var(--color-line-strong);
  border-radius: var(--radius-xs);
  background: var(--color-line);
  color: #4a5565;
  font-size: var(--font-meta);
  font-weight: var(--weight-black);
  white-space: nowrap;
}

.media-icon {
  flex: none;
  width: 12rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: var(--radius-pill);
}

.media-digital {
  border-color: #dbeafe;
  background: #edf5ff;
  color: var(--color-info);
}

.meta-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  min-height: 36rpx;
  margin-top: 15rpx;
  color: #6a7282;
  font-size: 22rpx;
  font-weight: var(--weight-medium);
}

.meta-label {
  color: #6a7282;
}

.meta-gap {
  margin-left: 10rpx;
}

.meta-value {
  color: #101828;
  font-size: 23rpx;
  font-weight: var(--weight-black);
}

.success-value {
  color: var(--color-success);
}

.meta-separator {
  width: 2rpx;
  height: 18rpx;
  margin: 0 8rpx;
  border-radius: var(--radius-pill);
  background: var(--color-line-strong);
}

.meta-muted {
  max-width: 230rpx;
  overflow: hidden;
  color: #6a7282;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.date-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 4rpx;
  color: #99a1af;
  font-size: var(--font-meta);
  font-weight: var(--weight-bold);
}

.result-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 58rpx;
  margin-top: 18rpx;
  padding: 0 12rpx;
  border: 1rpx solid rgba(255, 226, 226, 0.7);
  border-radius: 16rpx;
  background: linear-gradient(90deg, #fef2f2, #fff7ed);
}

.result-index {
  display: flex;
  align-items: center;
  gap: 7rpx;
  min-width: 0;
}

.result-icon {
  color: var(--color-brand);
  font-size: 20rpx;
  font-weight: var(--weight-black);
}

.result-label {
  color: #6a7282;
  font-size: 19rpx;
  font-weight: var(--weight-bold);
}

.result-value {
  color: var(--color-brand);
  font-size: 22rpx;
  font-weight: var(--weight-black);
}

.level-pill {
  flex: none;
  height: 32rpx;
  padding: 0 12rpx;
  border-radius: var(--radius-pill);
  background: #fff8df;
  color: #d99a11;
  font-size: var(--font-caption);
  font-weight: var(--weight-black);
  line-height: 32rpx;
}

.card-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 14rpx;
  min-height: 56rpx;
  margin-top: auto;
  padding-top: 14rpx;
}

.card-hint {
  display: flex;
  align-items: center;
  gap: 5rpx;
  min-width: 0;
  height: 36rpx;
  padding: 0 11rpx;
  border-radius: var(--radius-xs);
  background: #fffbeb;
  color: #fe9a00;
  font-size: 19rpx;
  font-weight: var(--weight-bold);
}

.card-hint text:last-child {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-hint-muted {
  background: transparent;
  color: #99a1af;
  padding-left: 0;
}

.hint-icon {
  flex: none;
  font-size: 18rpx;
}

.card-actions {
  flex: none;
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-left: auto;
}

.detail-button,
.sell-button,
.arrow-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48rpx;
  border-radius: var(--radius-pill);
  font-size: 19rpx;
  font-weight: var(--weight-bold);
  white-space: nowrap;
}

.detail-button {
  min-width: 72rpx;
  padding: 0 16rpx;
  background: var(--color-line);
  color: #6a7282;
}

.sell-button {
  min-width: 110rpx;
  padding: 0 18rpx;
  border: 1rpx solid #ffe2e2;
  background: #fef2f2;
  color: #ff3b30;
}

.arrow-button {
  width: 74rpx;
  background: var(--color-line);
  color: #6a7282;
  font-size: 28rpx;
  line-height: 1;
}

.empty-card {
  display: flex;
  align-items: center;
  flex-direction: column;
  padding: 70rpx 36rpx;
  border: 1rpx solid rgba(243, 244, 246, 0.86);
  border-radius: 40rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
  text-align: center;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: var(--radius-pill);
  background: rgba(239, 60, 53, 0.08);
  color: var(--color-brand);
  font-size: 44rpx;
  font-weight: var(--weight-medium);
}

.empty-title {
  margin-top: 26rpx;
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: var(--weight-black);
}

.empty-desc {
  margin-top: 12rpx;
  color: var(--color-text-muted);
  font-size: var(--font-body);
  font-weight: var(--weight-bold);
  line-height: 1.5;
}

.empty-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  margin-top: 34rpx;
  padding: 0 34rpx;
  border-radius: var(--radius-lg);
  background: var(--color-brand-bright);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: var(--weight-black);
  box-shadow: 0 8rpx 0 #cc2118, 0 16rpx 28rpx rgba(239, 60, 53, 0.22);
  transition: transform var(--motion-fast), box-shadow var(--motion-fast);
}

.empty-button-hover {
  transform: translateY(6rpx);
  box-shadow: 0 2rpx 0 #cc2118, 0 8rpx 18rpx rgba(239, 60, 53, 0.18);
}
