@import "../../styles/common.wxss";

page {
  background: var(--color-bg);
}

.add-page {
  min-height: 100vh;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
  background: var(--color-bg);
  color: var(--color-text);
}

button {
  box-sizing: border-box;
  min-width: 0;
  width: auto;
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: 0;
}

input,
textarea,
picker,
scroll-view {
  box-sizing: border-box;
  min-width: 0;
}

.add-hero {
  position: relative;
  min-height: 250rpx;
  padding: 88rpx 36rpx 118rpx;
  overflow: hidden;
  border-bottom-left-radius: var(--radius-hero);
  border-bottom-right-radius: var(--radius-hero);
  background: linear-gradient(135deg, var(--color-brand-bright) 0%, #e3271e 55%, var(--color-brand-deep) 100%);
  box-shadow: var(--shadow-brand);
}

.hero-gamepad {
  position: absolute;
  right: -42rpx;
  top: -24rpx;
  width: 310rpx;
  height: 230rpx;
  transform: rotate(-13deg);
  border: 18rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 72rpx;
  opacity: 0.92;
}

.pad-cross,
.pad-dot {
  position: absolute;
  background: rgba(255, 255, 255, 0.08);
}

.pad-cross-h {
  left: 62rpx;
  top: 94rpx;
  width: 70rpx;
  height: 20rpx;
  border-radius: var(--radius-pill);
}

.pad-cross-v {
  left: 87rpx;
  top: 69rpx;
  width: 20rpx;
  height: 70rpx;
  border-radius: var(--radius-pill);
}

.pad-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: var(--radius-pill);
}

.pad-dot-one {
  right: 58rpx;
  top: 58rpx;
}

.pad-dot-two {
  right: 26rpx;
  top: 104rpx;
}

.nav-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 68rpx;
  width: 68rpx;
  height: 68rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.13);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: transform var(--motion-fast), background-color var(--motion-fast);
}

.back-chevron {
  width: 18rpx;
  height: 18rpx;
  margin-left: 6rpx;
  border-left: 7rpx solid #ffffff;
  border-bottom: 7rpx solid #ffffff;
  border-radius: 3rpx;
  transform: rotate(45deg);
}

.back-button-hover {
  transform: scale(0.94);
  background: rgba(255, 255, 255, 0.2);
}

.title-block {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  min-width: 0;
}

.page-title {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: var(--weight-black);
  line-height: 1.12;
}

.page-subtitle {
  color: rgba(255, 255, 255, 0.82);
  font-size: var(--font-small);
  font-weight: var(--weight-bold);
}

.form-shell {
  position: relative;
  z-index: 2;
  margin-top: -84rpx;
  padding: 0 24rpx;
}

.form-card {
  padding: 30rpx;
  border: 1rpx solid rgba(243, 244, 246, 0.72);
  border-radius: var(--radius-xl);
  background: var(--color-surface);
  box-shadow: var(--shadow-soft);
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 26rpx;
}

.card-title-marker {
  width: 10rpx;
  height: 30rpx;
  border-radius: var(--radius-pill);
  background: currentColor;
}

.card-title {
  color: var(--color-text);
  font-size: 26rpx;
  font-weight: var(--weight-black);
}

.card-title-red {
  color: var(--color-brand-bright);
}

.card-title-amber {
  color: var(--color-warning);
}

.card-title-gray {
  color: #94a3b8;
}

.media-toggle {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-3);
  padding: 10rpx;
  border: 1rpx solid var(--color-line);
  border-radius: var(--radius-xl);
  background: var(--color-surface-muted);
}

.media-option {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  gap: var(--space-2);
  height: 78rpx;
  border-radius: var(--radius-lg);
  color: var(--color-text-muted);
  font-size: 24rpx;
  font-weight: var(--weight-black);
  transition: transform var(--motion-fast), background-color var(--motion-fast), color var(--motion-fast);
}

.media-option-active {
  background: #ffffff;
  color: var(--color-text);
  box-shadow: 0 8rpx 18rpx rgba(17, 24, 39, 0.06);
}

.media-dot {
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-radius: var(--radius-pill);
}

.form-field {
  margin-top: 32rpx;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  color: #4b5563;
  font-size: var(--font-small);
  font-weight: var(--weight-black);
}

.optional {
  color: var(--color-text-muted);
  font-weight: var(--weight-bold);
}

.text-input,
.date-input,
.note-input {
  box-sizing: border-box;
  width: 100%;
  border: 1rpx solid var(--color-line-strong);
  border-radius: var(--radius-lg);
  background: var(--color-surface-muted);
  color: var(--color-text);
  font-size: 26rpx;
  font-weight: var(--weight-bold);
}

.text-input {
  height: 90rpx;
  padding: 0 28rpx;
}

.input-placeholder {
  color: #a7afbd;
  font-weight: var(--weight-bold);
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip-row-small {
  gap: 12rpx;
}

.choice-chip,
.status-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 94rpx;
  height: 60rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--color-line-strong);
  border-radius: var(--radius-pill);
  background: #ffffff;
  color: #4b5563;
  font-size: 23rpx;
  font-weight: var(--weight-black);
  white-space: nowrap;
  transition: transform var(--motion-fast), box-shadow var(--motion-fast), background-color var(--motion-fast);
}

.choice-chip-small {
  min-width: 80rpx;
  height: 52rpx;
  padding: 0 22rpx;
  background: var(--color-surface-muted);
  font-size: 21rpx;
}

.choice-chip-active {
  border-color: var(--color-brand);
  background: var(--color-brand-bright);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(239, 60, 53, 0.24);
}

.choice-chip-active-soft {
  border-color: rgba(239, 60, 53, 0.18);
  background: rgba(239, 60, 53, 0.08);
  color: var(--color-brand);
}

.status-chip {
  min-width: 112rpx;
  height: 58rpx;
  gap: 8rpx;
}

.status-chip-active {
  border-color: rgba(16, 185, 129, 0.4);
  background: #eafaf3;
  color: #059669;
}

.check-mark {
  font-size: 22rpx;
}

.chip-hover {
  transform: translateY(3rpx);
}

.two-column {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-5);
}

.compact-field {
  margin-top: 0;
}

.money-input-wrap {
  position: relative;
}

.money-prefix {
  position: absolute;
  left: 24rpx;
  top: 25rpx;
  z-index: 1;
  color: var(--color-text-muted);
  font-size: 28rpx;
  font-weight: var(--weight-black);
}

.money-input {
  padding-left: 54rpx;
}

.date-input {
  display: flex;
  align-items: center;
  height: 90rpx;
  padding: 0 24rpx;
  color: var(--color-text-secondary);
}

.digital-note {
  margin-top: 30rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #dbeafe;
  border-radius: var(--radius-lg);
  background: #eff6ff;
  color: #3b5f9b;
  font-size: var(--font-small);
  font-weight: var(--weight-bold);
  line-height: 1.5;
}

.channel-scroll {
  width: 100%;
  white-space: nowrap;
}

.channel-strip {
  display: flex;
  gap: 14rpx;
  padding-bottom: 4rpx;
}

.upload-zone {
  width: 100%;
  height: 210rpx;
  overflow: hidden;
  border: 3rpx dashed var(--color-line-strong);
  border-radius: var(--radius-lg);
  background: var(--color-surface-muted);
  transition: transform var(--motion-fast), border-color var(--motion-fast);
}

.upload-zone-hover {
  transform: translateY(3rpx);
  border-color: rgba(239, 60, 53, 0.32);
}

.upload-zone-filled {
  border-style: solid;
}

.cover-preview {
  display: block;
  width: 100%;
  height: 100%;
}

.upload-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: var(--space-3);
  height: 100%;
  color: var(--color-text-muted);
  font-size: var(--font-small);
  font-weight: var(--weight-bold);
}

.upload-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 62rpx;
  border-radius: var(--radius-pill);
  background: #ffffff;
  color: var(--color-text-muted);
  font-size: 38rpx;
  font-weight: var(--weight-medium);
  box-shadow: 0 6rpx 16rpx rgba(17, 24, 39, 0.06);
}

.note-input {
  height: 164rpx;
  padding: 24rpx 28rpx;
  line-height: 1.5;
}

.bottom-actions {
  margin: 44rpx 24rpx 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.save-button,
.continue-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 90rpx;
  border-radius: var(--radius-lg);
  font-size: 26rpx;
  font-weight: var(--weight-black);
  transition: transform var(--motion-fast), box-shadow var(--motion-fast), background-color var(--motion-fast);
}

.save-button {
  gap: var(--space-3);
  background: var(--color-brand-bright);
  color: #ffffff;
  box-shadow: 0 8rpx 0 #cc2118, 0 16rpx 28rpx rgba(239, 60, 53, 0.24);
}

.save-button-hover {
  transform: translateY(6rpx);
  box-shadow: 0 2rpx 0 #cc2118, 0 8rpx 18rpx rgba(239, 60, 53, 0.2);
}

.save-button-disabled,
.continue-button-disabled {
  opacity: 0.72;
}

.button-check {
  font-size: 28rpx;
}

.continue-button {
  margin-top: 18rpx;
  border: 1rpx solid rgba(239, 60, 53, 0.12);
  background: rgba(239, 60, 53, 0.08);
  color: var(--color-brand);
}

.continue-button-hover {
  transform: translateY(3rpx);
  background: rgba(239, 60, 53, 0.13);
}
