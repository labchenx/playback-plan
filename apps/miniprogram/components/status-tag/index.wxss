@import "../../styles/tokens.wxss";

.status-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  border-radius: var(--radius-pill);
  background: var(--color-line);
  color: var(--color-text-secondary);
  font-size: var(--font-meta);
  font-weight: var(--weight-bold);
  white-space: nowrap;
}

.status-tag text {
  overflow: hidden;
  text-overflow: ellipsis;
}

.status-tag-floating {
  position: absolute;
  top: 13rpx;
  left: 13rpx;
  min-width: 38rpx;
  padding: 3rpx 10rpx;
  border-radius: var(--radius-xs);
  color: #ffffff;
  font-size: 15rpx;
  font-weight: var(--weight-black);
  text-align: center;
  box-shadow: 0 3rpx 7rpx rgba(0, 0, 0, 0.1);
}

.status-tag-muted {
  padding: 4rpx 13rpx;
}

.status-tag-platform-red {
  background: var(--color-brand);
}

.status-tag-platform-blue {
  background: #2563eb;
}

.status-tag-success {
  background: #eafaf3;
  color: var(--color-success);
}

.status-tag-warning {
  background: #fff8df;
  color: #d99a11;
}

.status-tag-info {
  background: #edf5ff;
  color: var(--color-info);
}
