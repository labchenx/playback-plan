@import "../../styles/tokens.wxss";

.stat-card {
  min-height: 116rpx;
  padding: 21rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.055);
}

.stat-card-hot {
  background: linear-gradient(135deg, #ff3f34, #df211c);
}

.stat-card-label-row,
.stat-card-value-row {
  display: flex;
  align-items: center;
}

.stat-card-label-row {
  gap: var(--space-2);
  color: var(--color-text-muted);
  font-size: 19rpx;
  font-weight: var(--weight-bold);
}

.stat-card-hot .stat-card-label-row {
  color: rgba(255, 255, 255, 0.88);
}

.stat-card-icon {
  width: 24rpx;
  height: 24rpx;
}

.stat-card-value-row {
  margin-top: 13rpx;
  align-items: baseline;
}

.stat-card-value {
  color: #ffffff;
  font-size: var(--font-number);
  font-weight: var(--weight-black);
  line-height: 1;
}

.stat-card-hot .stat-card-value {
  font-size: 46rpx;
}

.stat-card-unit {
  margin-left: 5rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-meta);
  font-weight: var(--weight-bold);
}
