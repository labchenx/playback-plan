@import "../../styles/tokens.wxss";

.game-cover-card {
  flex: 0 0 234rpx;
  width: 234rpx;
  white-space: normal;
}

.game-cover-card-image-wrap {
  position: relative;
  width: 234rpx;
  height: 268rpx;
  overflow: hidden;
  border: 1rpx solid rgba(243, 244, 246, 0.5);
  border-radius: var(--radius-md);
  background: var(--color-line);
  box-shadow: var(--shadow-cover);
}

.game-cover-card-image {
  width: 100%;
  height: 100%;
}

.game-cover-card-heirloom {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  width: 118rpx;
  height: 118rpx;
}

.game-cover-card-heirloom-img {
  display: block;
  width: 100%;
  height: 100%;
}

.game-cover-card-title {
  display: -webkit-box;
  min-height: 56rpx;
  margin-top: 17rpx;
  overflow: hidden;
  color: var(--color-text);
  font-size: 22rpx;
  font-weight: var(--weight-black);
  line-height: 1.28;
  text-overflow: ellipsis;
  white-space: normal;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.game-cover-card-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
  margin-top: 9rpx;
}

.game-cover-card-price {
  color: var(--color-brand);
  font-size: 25rpx;
  font-weight: var(--weight-black);
}

.game-cover-card-note {
  display: block;
  margin-top: var(--space-2);
  overflow: hidden;
  color: #b3bac5;
  font-size: var(--font-meta);
  font-weight: var(--weight-medium);
  text-overflow: ellipsis;
  white-space: nowrap;
}
