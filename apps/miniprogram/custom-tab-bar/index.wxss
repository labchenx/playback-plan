.bottom-tabs {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 12rpx 44rpx calc(12rpx + env(safe-area-inset-bottom));
  border-top-left-radius: 34rpx;
  border-top-right-radius: 34rpx;
  background: rgba(255, 255, 255, 1);
  box-shadow: 0 -14rpx 46rpx rgba(21, 29, 44, 0.08);
}

.tab-item {
  width: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #9ca3af;
  transition: transform 120ms ease, color 120ms ease;
}

.tab-item-hover {
  transform: translateY(4rpx);
}

.active-tab {
  color: #ef3c35;
}

.tab-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
}

.tab-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.tab-label {
  font-size: 17rpx;
  font-weight: 900;
}

.primary-tab {
  position: relative;
  top: -36rpx;
  color: #9ca3af;
  transition: transform 120ms ease;
}

.primary-tab-hover {
  transform: translateY(10rpx);
}

.primary-tab .tab-icon-wrap {
  width: 94rpx;
  height: 94rpx;
  border: 5rpx solid #f4f5f8;
  border-radius: 999rpx;
  background: #ff3b30;
  color: #ffffff;
  box-shadow: 0 9rpx 0 #c92520, 0 18rpx 30rpx rgba(255, 59, 48, 0.24);
  transition: transform 120ms ease, box-shadow 120ms ease;
}

.primary-tab-hover .tab-icon-wrap {
  box-shadow: 0 1rpx 0 #c92520, 0 10rpx 24rpx rgba(255, 59, 48, 0.2);
}

.primary-tab .tab-icon-img {
  width: 54rpx;
  height: 54rpx;
}

.primary-tab .tab-label {
  margin-top: 12rpx;
  color: #9ca3af;
}
